# GCP Production Configuration
# Copy this to .env.production and fill in your values
# This file is sourced by deploy/gcloud-setup.sh

# ===================
# GCP Project
# ===================
PROJECT_ID=your-gcp-project-id
REGION=us-central1
ZONE=us-central1-a
INSTANCE_NAME=make-nashville-wiki
MACHINE_TYPE=e2-medium

# ===================
# Domain
# ===================
DOMAIN=wiki.makenashville.org

# ===================
# Google Cloud Storage
# ===================
# Create HMAC keys at: https://console.cloud.google.com/storage/settings;tab=interoperability
GCS_BUCKET=make-nashville-wiki-uploads
GCS_ACCESS_KEY=your-gcs-hmac-access-key
GCS_SECRET_KEY=your-gcs-hmac-secret-key

# ===================
# Slack OAuth
# ===================
# Create app at: https://api.slack.com/apps
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# ===================
# Slack Notifications (optional)
# ===================
# Create an incoming webhook at: https://api.slack.com/apps → your app → Incoming Webhooks
SLACK_WEBHOOK_URL=

# ===================
# Uptime Monitoring (optional)
# ===================
# Optional: Home Assistant URL for uptime monitoring
HOME_ASSISTANT_URL=

# ===================
# Moodle LMS
# ===================
MOODLE_ADMIN_EMAIL=admin@makenashville.org

# ===================
# GRIT Automation
# ===================
GRIT_API_URL=
GRIT_API_KEY=

# ===================
# Secrets (auto-generated if left empty)
# ===================
# Leave these empty for auto-generation on first deploy
# Or set them manually if you need consistent values
SECRET_KEY=
UTILS_SECRET=
POSTGRES_PASSWORD=


# ===================
# Shlink
# ===================
SHLINK_DB_PASSWORD=

# ===================
# OAuth2 Proxy
# ===================
OAUTH2_PROXY_CLIENT_ID=
OAUTH2_PROXY_CLIENT_SECRET=
OAUTH2_PROXY_COOKIE_SECRET=
OAUTH2_PROXY_GOOGLE_GROUPS=
OAUTH2_PROXY_GOOGLE_ADMIN_EMAIL=

# ===================
# n8n
# ===================
N8N_DB_PASSWORD=
N8N_ENCRYPTION_KEY=
MOODLE_DB_PASSWORD=
MOODLE_ADMIN_PASSWORD=
MOODLE_WEBHOOK_SECRET=
