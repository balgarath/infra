# ===================
# Domain Configuration
# ===================
# For local: localhost / https://localhost
# For production: wiki.yourdomain.com / https://wiki.yourdomain.com
DOMAIN=localhost
URL=https://localhost

# ===================
# Outline
# ===================
NODE_ENV=production
SECRET_KEY=generate-a-32-byte-hex-string
UTILS_SECRET=generate-another-32-byte-hex-string
PORT=3000
HOST=0.0.0.0

# ===================
# Database
# ===================
DATABASE_URL=postgres://outline:outline@postgres:5432/outline
PGSSLMODE=disable
POSTGRES_USER=outline
POSTGRES_PASSWORD=outline
POSTGRES_DB=outline

# ===================
# Redis
# ===================
REDIS_URL=redis://redis:6379

# ===================
# Storage
# ===================
FILE_STORAGE=s3
FILE_STORAGE_UPLOAD_MAX_SIZE=262144000
AWS_S3_UPLOAD_BUCKET_NAME=outline

# For local development (MinIO):
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
AWS_S3_UPLOAD_BUCKET_URL=http://minio:9000
AWS_S3_FORCE_PATH_STYLE=true

# For production (Google Cloud Storage):
# GCS with uniform bucket-level access requires AWS_S3_ACL=private so the DB
# record is valid, but the ACL field is never sent to GCS (see deploy/S3Storage.js).
# Create HMAC keys at: https://console.cloud.google.com/storage/settings;tab=interoperability
# AWS_S3_ACL=private
# AWS_ACCESS_KEY_ID=your-gcs-hmac-access-key
# AWS_SECRET_ACCESS_KEY=your-gcs-hmac-secret
# AWS_REGION=auto
# AWS_S3_UPLOAD_BUCKET_URL=https://storage.googleapis.com
# AWS_S3_FORCE_PATH_STYLE=true

# ===================
# MinIO (local only)
# ===================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ===================
# Authentication
# ===================
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=

# ===================
# n8n
# ===================
N8N_DB_PASSWORD=n8n
N8N_ENCRYPTION_KEY=generate-a-hex-string
